{
  "name": "kinetitext",
  "version": "1.4.0",
  "description": "Modular web crawler for novels with retry mechanism, audio conversion, merging, and MP4 support",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "backup": "bun run scripts/backup.ts",
    "retry-failed": "bun run scripts/retry_failed.ts",
    "clean": "bun run scripts/clean_noise.ts",
    "audiobook": "bun run scripts/generate_audiobook.ts",
    "to-mp4": "bun run scripts/mp3_to_mp4.ts",
    "merge-mp3": "bun run scripts/merge_mp3.ts",
    "clean-files": "bun run scripts/clean_novels.ts",
    "verify": "bun run scripts/verify_chapters.ts",
    "profile": "bun run scripts/profile_adapter.ts",
    "bench:convert": "bun run scripts/bench_convert.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "music-metadata": "^11.12.3",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "puppeteer": "^24.38.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  }
}
