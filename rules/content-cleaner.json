  "noisePatterns": {
    "_global": [
      {
        "pattern": ">>章節報錯<<",
        "flags": "g"
      },
      {
        "pattern": "關燈|護眼|字體：|字號|大|中|小",
        "flags": "g"
      },
      {
        "pattern": "\\(adsbygoogle.*?;",
        "flags": "g"
      },
      {
        "pattern": "window\\.mg_asy_a\\s*=.*?\\}\\)\\(\\);",
        "flags": "gs"
      },
      {
        "pattern": "\\d+\\s*(頁|頁碼|P\\.?|p\\.?|Chapter)",
        "flags": "g"
      },
      {
        "pattern": "作者簽名.*",
        "flags": "gi"
      },
      {
        "pattern": "———+.*",
        "flags": "g"
      },
      {
        "pattern": "===.*",
        "flags": "g"
      }
    ],
    "8novel": [
      {
        "pattern": "[8８⒏⑻⑧][\\s]*[nｎＮ][\\s]*[oｏＯσο][\\s]*[vｖＶν][\\s]*[eｅＥЁ][\\s]*[lｌＬ┗└][\\s]*[.．·。][\\s]*[cｃＣС][\\s]*[oｏＯοο][\\s]*[mｍＭｍ]",
        "flags": "ig"
      }
    ],
    "wfxs": [
      {
        "pattern": "網腐小說",
        "flags": "g"
      },
      {
        "pattern": "\\[.*?首發\\]",
        "flags": "g"
      }
    ],
    "czbooks": [
      {
        "pattern": "『PS:.*?』",
        "flags": "ig"
      },
      {
        "pattern": "————以下正文————",
        "flags": "g"
      },
      {
        "pattern": "【.*?】",
        "flags": "g"
      }
    ],
    "twkan": [
      {
        "pattern": "台灣小說網解書荒[，,].*?超方便[\\s]*",
        "flags": "g"
      }
    ]
